# Strapi base URL (no trailing slash)
REACT_APP_STRAPI_URL=https://holleman-cms-production.up.railway.app

# Strapi API token for the upload endpoint.
# Generate one in the Strapi admin: Settings → API Tokens → Create new token
# Minimum required permission: plugin::upload.upload (or "Media Library" → Upload)
REACT_APP_STRAPI_UPLOAD_TOKEN=your_token_here
